# =============================================================================
# FOR VALIDATORS ONLY
# =============================================================================
# Copy this file to .env and fill in your API keys

# =============================================================================
# Network Configuration
# =============================================================================
SUBTENSOR_NETWORK=finney

# =============================================================================
# Supabase (REQUIRED)
# =============================================================================
SUPABASE_URL=https://qplwoislplkcegvdmbim.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =============================================================================
# Sourcing Validation APIs (REQUIRED)
# =============================================================================

# TrueList - Email verification (Stage 3)
# https://truelist.io/
TRUELIST_API_KEY=your_truelist_api_key_here

# Fulfillment website-existence check timeout (FULFILLMENT WORKERS ONLY)
# Caps how long verify_company() will wait on the GET fallback when a
# lead's company website is slow / cold-starting (Webflow, Squarespace,
# static creator hosts).  The HEAD request stays at a fixed 10s; this
# only affects the GET fallback that runs when HEAD fails.
# Default is 30s in the deploy script (FF workers).  Qualification workers
# leave it unset → falls back to the 10s code default, so qualification
# scoring behaviour is unchanged.
FULFILLMENT_WEBSITE_TIMEOUT_S=30

# ZeroBounce - Catch-all email fallback (FULFILLMENT ONLY)
# Only consulted when TrueList classifies an email as accept_all / ok_for_all.
# Used in the fulfillment scoring path; sourcing and qualification ignore this
# key entirely.  Leaving it blank just disables the fallback (catch-all leads
# stay rejected, which is the pre-2026-04-30 behaviour).
# https://www.zerobounce.net/
ZEROBOUNCE_API_KEY=your_zerobounce_api_key_here

# ScrapingDog - LinkedIn/Google Search validation (Stage 4 & 5)
# https://www.scrapingdog.com/
SCRAPINGDOG_API_KEY=your_scrapingdog_api_key_here

# OpenRouter - LLM inference for scoring
# https://openrouter.ai/
OPENROUTER_KEY=your_openrouter_key_here

# =============================================================================
# Qualification APIs (REQUIRED for model evaluation)
# =============================================================================
# These are SEPARATE keys from sourcing — used only for qualification
# model evaluation. Keeps billing and rate limits isolated.

QUALIFICATION_SCRAPINGDOG_API_KEY=your_qualification_scrapingdog_key_here
QUALIFICATION_OPENROUTER_API_KEY=your_qualification_openrouter_key_here

# Qualification leads table (set by deployment scripts)
QUALIFICATION_LEADS_TABLE=test_leads_for_miners

# =============================================================================
# Reputation Score APIs (OPTIONAL)
# =============================================================================
# Most reputation checks use free public APIs (no key needed):
# - Wayback Machine
# - SEC EDGAR
# - GDELT
# - WHOIS/DNSBL
#
# Optional paid APIs for enhanced reputation scoring:
COMPANIES_HOUSE_API_KEY=your_companies_house_key_here

# =============================================================================
# Research Lab trajectory capture (trajectoryimprovements.md P5/P16)
# =============================================================================
# The capture-enabled flags default true, but capture is INERT without the S3
# destinations below. In production (production writes enabled) workers refuse
# to start when a channel is enabled but its destination/KMS key is unset —
# see gateway/research_lab/capture_health.py.

# Raw OpenRouter request/response traces (hosted loop engine)
RESEARCH_LAB_RAW_TRACE_S3_PREFIX=s3://your-bucket/research-lab
# Scorer judgment breakdown artifacts
RESEARCH_LAB_SCORER_TRACE_S3_PREFIX=s3://your-bucket/research-lab
# Raw/scorer trace SSE-KMS key (required in production)
RESEARCH_LAB_TRACE_KMS_KEY_ID=alias/your-trace-kms-key
# Private-model in-container provider traces (prefix AND KMS key are both
# required — unencrypted uploads are refused)
RESEARCH_LAB_INCONTAINER_TRACE_S3_PREFIX=s3://your-bucket/research-lab/incontainer-traces
RESEARCH_LAB_INCONTAINER_TRACE_KMS_KEY_ID=alias/your-kms-key
# Supabase corpus projection (schema 27 tables) — required in production
RESEARCH_LAB_TRAJECTORY_PROJECTOR_ENABLED=true
# Explicit execution_traces -> research_trajectories join key (requires script 64)
RESEARCH_LAB_EXECUTION_TRACE_TRAJECTORY_ID_ENABLED=true
# Escape hatch: start a production worker with degraded capture (loud error)
# RESEARCH_LAB_CAPTURE_HEALTH_ALLOW_DEGRADED=true
