# Exclude sensitive files
secrets/
*.pem
*.key
service_account_key.json

# Exclude logs and runtime data
logs/
*.log
gateway.log
validation_artifacts/
hotpatch-backups/
*.bak
*.tmp
*.pid

# Exclude generated enclave/build artifacts from the next enclave image build.
# The EIF is produced from the image; copying an old EIF into the image bloats
# the build context and can exhaust the gateway root volume.
tee/*.eif
tee-enclave.eif
_attested_runtime/**/*.pyc
_attested_runtime/**/__pycache__/

# Exclude Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Exclude build artifacts
*.egg-info/
dist/
build/
*.so

# Exclude venv and node_modules
venv/
env/
node_modules/

# Exclude git
.git/
.gitignore

# Exclude Docker and deployment files
docker-compose*.yml
Dockerfile*
.dockerignore
BUILD_INFO.json

# The staging script creates the complete normalized image source. Docker sees
# no live gateway files other than this tree, so host metadata cannot affect PCR0.
*
!_enclave_source/
!_enclave_source/**

# Exclude test and temp files
*.swp
*.swo
*~
.DS_Store
