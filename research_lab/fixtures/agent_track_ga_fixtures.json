  "invalid_ga_criteria": [
    {
      "id": "bad-approved-from-local",
      "overrides": {
        "criteria_approved": true,
        "state": "ready_after_owner_policy"
      },
      "expected_error_contains": [
        "cannot be claimed from local fixtures",
        "cannot be claimed by a local_only record",
        "owner_approval_ref"
      ]
    },
    {
      "id": "bad-low-stake-threshold",
      "overrides": {
        "stake_threshold_usd": 100
      },
      "expected_error_contains": "stake_threshold_usd"
    },
    {
      "id": "bad-low-funded-loops",
      "overrides": {
        "min_funded_loop_count": 5
      },
      "expected_error_contains": "min_funded_loop_count"
    },
    {
      "id": "bad-low-clean-receipts",
      "overrides": {
        "min_clean_receipt_count": 5
      },
      "expected_error_contains": "min_clean_receipt_count"
    },
    {
      "id": "bad-approved-without-entropy",
      "base": "ready_ga_criteria",
      "overrides": {
        "require_entropy_accounting_live": false
      },
      "expected_error_contains": "live entropy accounting"
    },
    {
      "id": "bad-protected-token",
      "overrides": {
        "workspace_access_token": "workspace access token: secret"
      },
      "expected_error_contains": "protected material"
    },
    {
      "id": "bad-production-writes",
      "overrides": {
        "production_writes": true
      },
      "expected_error_contains": "must not enable production writes"
    }
  ],
