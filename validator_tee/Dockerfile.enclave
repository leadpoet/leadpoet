# ============================================================
# VALIDATOR ENCLAVE DOCKERFILE
# ============================================================
# This Dockerfile builds the validator TEE enclave image.
#
# TWO-STAGE REPRODUCIBILITY:
# 1. Base image (Dockerfile.base) - built ONCE with yum install, cached
# 2. This Dockerfile - uses base, only does COPY operations = deterministic
#
# IMPORTANT: Before building, ensure base image exists:
#   docker build -f validator_tee/Dockerfile.base -t validator-base:v1 .
#
# WHY THIS APPROACH?
# - yum install is non-deterministic (different file order each time)
# - By using a cached base image, we skip the non-deterministic step
# - All operations here (COPY, pip install) become deterministic
# - Combined with post-build timestamp normalization = reproducible PCR0
#
# HOW TO UPDATE (for security patches):
# 1. Rebuild base image (see Dockerfile.base)
# 2. Rebuild this image
# ============================================================

# Use the pre-built base image with Python already installed
# This MUST be built first: docker build -f Dockerfile.base -t validator-base:v1 .
FROM validator-base:v1

# =============================================================================
# Set SOURCE_DATE_EPOCH for reproducible timestamps
# This forces all file timestamps to 1970-01-01 00:00:00 UTC
# =============================================================================
ENV SOURCE_DATE_EPOCH=0

# Copy requirements and install dependencies
# --no-cache-dir: prevents pip cache from affecting image
# --no-compile: skips .pyc generation (bytecode has embedded timestamps)
COPY validator_tee/enclave/requirements.txt /tmp/requirements.txt
RUN python3 -m pip install --no-cache-dir --no-compile -r /tmp/requirements.txt

# V2 hotkey signing uses the last sr25519 wheel published for the enclave's
# pinned CPython 3.7 ABI. The parent build stages this exact hash from
# runtime-artifacts-v2.lock.json before Docker sees the context.
COPY .validator-tee-artifacts/py_sr25519_bindings-0.2.2-cp37-cp37m-manylinux_2_17_x86_64.manylinux2014_x86_64.whl /tmp/sr25519.whl
RUN python3 -m pip install --no-cache-dir --no-compile --no-deps /tmp/sr25519.whl \
    && rm -f /tmp/sr25519.whl

# =============================================================================
# CRITICAL: Delete ALL .pyc files and __pycache__ directories
# Even with --no-compile, pip may create .pyc files in some edge cases.
# These files contain embedded timestamps that cause PCR0 mismatches.
# This cleanup ensures reproducible builds across different machines/instances.
# =============================================================================
RUN find /usr -type f -name "*.pyc" -delete 2>/dev/null || true \
    && find /usr -type f -name "*.pyo" -delete 2>/dev/null || true \
    && find /usr -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true

# =============================================================================
# Normalize timestamps on all installed Python packages
# Even with SOURCE_DATE_EPOCH, some tools ignore it
# =============================================================================
RUN find /usr/lib/python3.7 -type f -exec touch -t 197001010000.00 {} + 2>/dev/null || true
RUN find /usr/lib64/python3.7 -type f -exec touch -t 197001010000.00 {} + 2>/dev/null || true

# Set working directory
WORKDIR /app

RUN mkdir -p \
    /app/gateway/db \
    /app/gateway/qualification \
    /app/gateway/tasks \
    /app/qualification \
    /app/scripts

# Copy enclave-specific files (runs INSIDE the enclave)
COPY validator_tee/enclave/ /app/validator_tee/enclave/
COPY validator_tee/runtime-artifacts-v2.lock.json /app/validator_tee/runtime-artifacts-v2.lock.json
COPY .validator-tee-artifacts/manifest.json /app/validator_tee/runtime-artifacts-v2.manifest.json

# Copy leadpoet_canonical module (for canonical weight hashing)
COPY leadpoet_canonical/ /app/leadpoet_canonical/

# Copy Research Lab verifier and gateway-owned scoring source inputs.
# These files are included so PCR0 changes whenever Research Lab scoring,
# promotion, audit-bundle, verifier, or ICP-window logic changes.
COPY leadpoet_verifier/ /app/leadpoet_verifier/
COPY research_lab/ /app/research_lab/
COPY gateway/__init__.py /app/gateway/__init__.py
COPY gateway/research_lab/ /app/gateway/research_lab/
COPY gateway/qualification/__init__.py /app/gateway/qualification/__init__.py
COPY gateway/qualification/models.py /app/gateway/qualification/models.py
COPY gateway/qualification/config.py /app/gateway/qualification/config.py
COPY gateway/qualification/utils/ /app/gateway/qualification/utils/
COPY gateway/db/__init__.py /app/gateway/db/__init__.py
COPY gateway/db/client.py /app/gateway/db/client.py
COPY gateway/tasks/__init__.py /app/gateway/tasks/__init__.py
COPY gateway/tasks/icp_generator.py /app/gateway/tasks/icp_generator.py
COPY qualification/__init__.py /app/qualification/__init__.py
COPY qualification/scoring/ /app/qualification/scoring/
COPY scripts/run_research_lab_hosted_worker.py /app/scripts/run_research_lab_hosted_worker.py
COPY scripts/run_research_lab_hosted_worker_fleet.py /app/scripts/run_research_lab_hosted_worker_fleet.py
COPY scripts/run_research_lab_scoring_worker.py /app/scripts/run_research_lab_scoring_worker.py
COPY scripts/run_research_lab_scoring_worker_fleet.py /app/scripts/run_research_lab_scoring_worker_fleet.py

# =============================================================================
# CRITICAL: Include validation logic for PCR0 verification
# These files are included in the enclave image so they're part of PCR0.
# If validator.py or automated_checks.py changes, PCR0 changes.
# The gateway independently builds this image to verify PCR0.
# =============================================================================
COPY neurons/validator.py /app/neurons/validator.py
COPY validator_models/automated_checks.py /app/validator_models/automated_checks.py

# =============================================================================
# Normalize timestamps on all copied application files
# This ensures COPY commands don't introduce timestamp variations
# =============================================================================
RUN find /app -type f -exec touch -t 197001010000.00 {} +

# Run the validator TEE service
# -u flag: unbuffered output (CRITICAL for debugging)
ENTRYPOINT ["python3", "-u", "/app/validator_tee/enclave/tee_service.py"]
